{
    "name": "sommark-playground",
    "version": "1.1.0",
    "type": "module",
    "main": "./dist/sommark-playground.umd.js",
    "module": "./dist/sommark-playground.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/sommark-playground.es.js",
            "require": "./dist/sommark-playground.umd.js"
        },
        "./style.css": "./dist/style.css"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:lib": "VITE_BUILD_MODE=lib tsc && VITE_BUILD_MODE=lib vite build",
        "preview": "vite preview",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d dist"
    },
    "devDependencies": {
        "@types/node": "^25.3.2",
        "gh-pages": "^6.3.0",
        "typescript": "^5.2.2",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4"
    },
    "dependencies": {
        "ansi-to-html": "^0.7.2",
        "highlight.js": "^11.9.0",
        "marked": "^17.0.1",
        "sommark": "^3.0.0"
    }
}
